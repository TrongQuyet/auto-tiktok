# AI Provider: "gemini", "openai", or "anthropic"
AI_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Pexels API
PEXELS_API_KEY=your_pexels_api_key

# TikTok credentials
TIKTOK_USERNAME=your_tiktok_username
TIKTOK_PASSWORD=your_tiktok_password

# Video settings
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=30
VIDEO_MAX_DURATION=60

# TTS voice (edge-tts voice name)
TTS_VOICE=en-US-ChristopherNeural

# Output paths
OUTPUT_DIR=./output
TEMP_DIR=./temp

# Chrome profile (persistent login)
CHROME_PROFILE_DIR=./chrome_profile

# Default content niche
DEFAULT_NICHE=motivation
